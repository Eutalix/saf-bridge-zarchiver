<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="SAF Plugin for ZArchiver"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ZArchiverSafBridge">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ZArchiverSafBridge">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            
            <!-- 
                This action allows ZArchiver to discover the plugin.
            -->
            <intent-filter>
                <action android:name="ru.zdevs.zarchiver.plugin.PLUGIN_APPLICATION" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- 
            1. name: Points to '.provider.SafContentProvider' (new package).
            2. authorities: Uses ${applicationId} to match 'com.eutalix.safbridge'.
            3. permission: REMOVED. We must NOT require permissions, otherwise 
               ZArchiver cannot query us.
        -->
        <provider
            android:name=".provider.SafContentProvider"
            android:authorities="${applicationId}"
            android:exported="true"
            android:grantUriPermissions="true" />

    </application>
</manifest>